---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Invoices" active="invoices">
  <div class="main-area">
    <div class="topbar"><div><div class="eyebrow">POS MANAGEMENT</div><h1>Smart POS Billing</h1></div></div>
    <div id="staffSection" class="card">
      <div class="cashier-badge" style="margin-bottom: 20px;"><span>Station Cashier: </span><strong id="activeStaffName">Loading...</strong></div>

      <form id="invoiceForm">
        <div class="form-grid">
          <div class="field"><label>Invoice No</label><input type="text" id="invNumber" readonly style="background:#f5f6f8" /></div>
          <div class="field"><label>Customer Phone</label><input type="text" id="invCustomerPhone" required /></div>
          <div class="field"><label>Customer Name</label><input type="text" id="invCustomerName" required /></div>
        </div>
        <div class="form-grid">
          <div class="field"><label>Product</label><select id="prodSelect" class="field" required><option value="">Select...</option></select></div>
          <div class="field"><label>Price</label><input type="number" id="prodPrice" readonly /></div>
          <div class="field"><label>Qty</label><input type="number" id="prodQty" value="1" required /></div>
        </div>
        <div class="field"><label>Discount</label><input type="number" id="prodDiscount" value="0" /></div>
        <div class="field"><label>Final Amount</label><input type="text" id="finalAmount" readonly /></div>
        <button type="submit" id="btnGen" class="btn btn-accent" style="width:100%">Generate Invoice</button>
      </form>

      <div id="formError" style="display:none; color:red; margin:10px 0;"></div>
      <div id="printArea" style="display:none; padding:20px; border:1px solid #ccc; margin-top:10px; background:#fff;">
         <h2 id="printInvNum"></h2>
         <p id="printCustomer"></p>
         <div id="printItems"></div>
         <h3 id="printTotal"></h3>
      </div>
      
      <button id="btnPrint" class="btn btn-primary" style="display:none; width:100%; margin-top:10px;" onclick="window.print()">🖨️ Print Invoice</button>
    </div>
  </div>
</Layout>

<style is:global>
  @media print {
    body * { visibility: hidden !important; }
    #printArea, #printArea * { visibility: visible !important; }
    #printArea { position: absolute !important; left: 0 !important; top: 0 !important; width: 100% !important; }
  }
</style>

<script is:inline>
  const API_BASE = 'http://localhost:5000/api';
  const pSelect = document.getElementById('prodSelect'), price = document.getElementById('prodPrice'),
        qty = document.getElementById('prodQty'), disc = document.getElementById('prodDiscount'), final = document.getElementById('finalAmount');

  function recalc() { final.value = Math.max(0, (price.value * qty.value) - disc.value); }
  [qty, disc].forEach(el => el.addEventListener('input', recalc));
  pSelect.addEventListener('change', () => { price.value = pSelect.options[pSelect.selectedIndex].dataset.price || 0; recalc(); });

  window.onload = async () => {
    document.getElementById('invNumber').value = 'INV-' + Date.now();
    const user = JSON.parse(localStorage.getItem('user') || '{}');
    document.getElementById('activeStaffName').textContent = user.name || 'Staff';
    try {
      const res = await fetch(`${API_BASE}/products`, { headers: { Authorization: `Bearer ${localStorage.getItem('token')}` } });
      const data = await res.json();
      data.forEach(p => {
        const opt = document.createElement('option');
        opt.value = p._id; opt.dataset.price = p.price;
        opt.textContent = `${p.name} (${p.stock ?? p.quantity ?? 0} left)`;
        pSelect.appendChild(opt);
      });
    } catch (err) { console.error(err); }
  };

  document.getElementById('invoiceForm').onsubmit = async (e) => {
    e.preventDefault();
    const payload = {
        invoiceNumber: document.getElementById('invNumber').value,
        customerName: document.getElementById('invCustomerName').value,
        customerPhone: document.getElementById('invCustomerPhone').value,
        items: [{ product: pSelect.value, quantity: qty.value, price: price.value }],
        totalAmount: final.value, discountAmount: disc.value, status: 'Paid'
    };
    
    try {
      const res = await fetch(`${API_BASE}/invoices`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', Authorization: `Bearer ${localStorage.getItem('token')}` },
        body: JSON.stringify(payload)
      });
      if (res.ok) {
        // Show Print Preview
        document.getElementById('printInvNum').textContent = "Invoice: " + payload.invoiceNumber;
        document.getElementById('printCustomer').textContent = "Customer: " + payload.customerName;
        document.getElementById('printItems').innerHTML = `Item: ${pSelect.options[pSelect.selectedIndex].text} x ${qty.value} = Rs ${final.value}`;
        document.getElementById('printTotal').textContent = "Total Amount: Rs " + final.value;
        
        document.getElementById('printArea').style.display = 'block';
        document.getElementById('btnGen').style.display = 'none';
        document.getElementById('btnPrint').style.display = 'block';
        alert('Invoice Generated!');
      }
    } catch (err) { alert('Error generating invoice'); }
  };
</script>